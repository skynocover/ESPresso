// ESPresso WiFi / OTA 憑證範本
//
// 複製成同目錄下的 secrets.h 並填入你的值；secrets.h 已被 .gitignore 忽略，
// 不會進版控。憑證以明碼寫進 flash — 個人桌面裝置可接受，勿放共用/正式祕密。
//
//     cp include/secrets.h.example include/secrets.h
//
#pragma once

#define WIFI_SSID "your-wifi-ssid"
#define WIFI_PASS "your-wifi-password"

// ArduinoOTA 上傳密碼 (擋區網內的流氓上傳)。pio 端用 --auth=<這個值> 上傳。
#define OTA_PASS "your-ota-password"
